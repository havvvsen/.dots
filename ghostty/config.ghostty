theme = Catppuccin Mocha
command = /usr/bin/zellij
font-family = "VictorMono Nerd Font"
font-family-bold = "VictorMono Nerd Font Bold"
font-family-italic = "VictorMono NF Italic"
font-family-bold-italic = "VictorMono NF Bold Italic "
font-size = 11.25

window-decoration= none
confirm-close-surface = false
background-opacity = 0.8

keybind = ctrl+c=copy_to_clipboard:mixed
keybind = ctrl+v=paste_from_clipboard
keybind = ctrl+shift+c=unbind
keybind = ctrl+shift+c=text:\x03
